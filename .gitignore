/.next
/out

# Logs
/logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Coverage directory used by testing tools
/coverage

# Misc
.DS_Store
Thumbs.db
*.pem

# TypeScript
*.tsbuildinfo

# Dotenv and similar local-only files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.local
